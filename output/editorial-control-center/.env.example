# Environment variables for Editorial Control Center
# .env.local is auto-generated — edit it for local overrides

# Database
# Matches the postgres service exposed by docker-compose.yml
DATABASE_URI=postgresql://postgres:postgres@localhost:5478/editorial_control_center
POSTGRES_PORT=5478  # Used by docker-compose; change if 5478 is already in use

PAYLOAD_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-to-a-random-secret

# Media storage
# Keep the adapter local for ST-009. The directory is resolved relative to the project root.
MEDIA_STORAGE_ADAPTER=local-filesystem
MEDIA_STORAGE_DIR=media
MEDIA_MAX_FILE_SIZE_BYTES=10485760

# Backups
BACKUP_DIR=backups/postgres
BACKUP_RETENTION_COUNT=7
POSTGRES_TOOL_MODE=auto
POSTGRES_DOCKER_SERVICE=postgres
# RESTORE_DATABASE_NAME=editorial_control_center_restore_test
# ALLOW_IN_PLACE_RESTORE=0
